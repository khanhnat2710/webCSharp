@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main class="main-shell">
        <header class="top-row">
            <div>
                <p class="eyebrow">Trang quản trị</p>
                <h1>Quản lý web bán điện thoại</h1>
            </div>
            <div class="top-row-actions">
                <a class="top-link" href="/">Trang chủ</a>
                <a class="top-link top-link-primary" href="/Customers">Khách hàng</a>
            </div>
        </header>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Đã xảy ra lỗi ngoài dự kiến.
    <a href="." class="reload">Tải lại</a>
    <span class="dismiss">🗙</span>
</div>
