@page "/Admins"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.Admins
@inject IAdminService AdminService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Quản trị viên</h3>
            <p class="page-subtitle">Quản lý tài khoản nội bộ và quyền truy cập hệ thống.</p>
        </div>
        <div class="toolbar">
            <a href="/Admins/Create" class="btn btn-primary">Thêm quản trị viên</a>
        </div>
    </div>

    <div class="data-card">
        <table class="table table-borderless align-middle">
            <thead>
            <tr>
                <th>Id</th>
                <th>Tên</th>
                <th>Email</th>
                <th>Mật khẩu</th>
                <th>Vai trò</th>
                <th>Thao tác</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var admin in _admins)
            {
                <tr>
                    <td>@admin.Id</td>
                    <td>@admin.Name</td>
                    <td>@admin.Email</td>
                    <td>@admin.Password</td>
                    <td>@admin.Role</td>
                    <td class="cell-actions">
                        <a href="/Admins/@admin.Id/Edit" class="btn btn-primary">Sửa</a>
                        <button class="btn btn-danger" type="button" @onclick="() => DeleteAdmin(admin.Id)">Xóa</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@code {
    List<Admin> _admins = new List<Admin>();

    protected override async Task OnInitializedAsync()
    {
        _admins = await AdminService.GetAllAdminsAsync();
    }

    private async Task DeleteAdmin(int Id)
    {
        await AdminService.DeleteAdminAsync(Id);
        _admins = await AdminService.GetAllAdminsAsync();
    }
}
