@page "/Edit"
@page "/Admins/{Id:int}/Edit"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.Admins
@inject IAdminService AdminService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Sửa quản trị viên</h3>
            <p class="page-subtitle">Cập nhật thông tin tài khoản quản trị.</p>
        </div>
    </div>

    <div class="form-card">
        <EditForm Model="admin" FormName="updateAdmin" OnValidSubmit="SaveAdmin" class="stack-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Tên</label>
                <InputText @bind-Value="admin.Name" class="form-control" />
                <ValidationMessage For="() => admin.Name"/>
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="admin.Email" class="form-control" />
                <ValidationMessage For="() => admin.Email"/>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <InputText @bind-Value="admin.Password" class="form-control" />
                <ValidationMessage For="() => admin.Password"/>
            </div>

            <div class="form-group">
                <label>Vai trò</label>
                <InputSelect @bind-Value="admin.Role" class="form-select">
                    <option value="Admin">Quản trị viên</option>
                    <option value="Staff">Nhân viên</option>
                </InputSelect>
                <ValidationMessage For="() => admin.Role"/>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
                <a class="btn btn-outline-primary" href="/Admins">Quay lại</a>
            </div>
        </EditForm>
    </div>
</section>

@code {
    public Admin admin = new Admin();
    [Parameter] public int Id { get; set; }
    [Inject] private NavigationManager _navigationManager { get; set; }

    protected override async Task OnInitializedAsync()
    {
        admin = await AdminService.GetAdminByIdAsync(Id);
    }

    protected async Task SaveAdmin()
    {
        admin.Id = Id;
        await AdminService.UpdateAdminAsync(admin);
        _navigationManager.NavigateTo("/Admins", true);
    }
}
