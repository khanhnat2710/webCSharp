@page "/Brands/Edit"
@rendermode InteractiveServer
@page "/Brands/{Id:int}/Edit"
@using BlazorWeb.Models
@using BlazorWeb.Services.brands
@inject IBrandService BrandService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Sửa thương hiệu</h3>
            <p class="page-subtitle">Cập nhật thông tin thương hiệu đang chọn.</p>
        </div>
    </div>

    <div class="form-card">
        <EditForm Model="brand" FormName="updateBrand" OnValidSubmit="SaveBrand" class="stack-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Tên</label>
                <InputText @bind-Value="brand.Name" class="form-control" />
                <ValidationMessage For="() => brand.Name"/>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
                <a class="btn btn-outline-primary" href="/Brands">Quay lại</a>
            </div>
        </EditForm>
    </div>
</section>

@code {
    public Brand brand = new Brand();
    [Parameter] public int Id { get; set; }
    [Inject] private NavigationManager _navigationManager { get; set; }

    protected override async Task OnInitializedAsync()
    {
        brand = await BrandService.GetBrandByIdAsync(Id);
    }

    protected async Task SaveBrand()
    {
        brand.Id = Id;
        await BrandService.UpdateBrandAsync(brand);
        _navigationManager.NavigateTo("/Brands", true);
    }
}
