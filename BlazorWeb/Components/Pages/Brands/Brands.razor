@page "/Brands"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.brands
@inject IBrandService BrandService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Thương hiệu</h3>
            <p class="page-subtitle">Quản lý danh sách hãng điện thoại và nhà sản xuất.</p>
        </div>
        <div class="toolbar">
            <a href="/Brands/Create" class="btn btn-primary">Thêm thương hiệu</a>
        </div>
    </div>

    <div class="data-card">
        <table class="table table-borderless align-middle">
            <thead>
            <tr>
                <th>Id</th>
                <th>Tên</th>
                <th>Thao tác</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var brand in _brands)
            {
                <tr>
                    <td>@brand.Id</td>
                    <td>@brand.Name</td>
                    <td class="cell-actions">
                        <a href="/Brands/@brand.Id/Edit" class="btn btn-primary">Sửa</a>
                        <button class="btn btn-danger" type="button" @onclick="() => DeleteBrand(brand.Id)">Xóa</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@code {
    List<Brand> _brands = new List<Brand>();

    protected override async Task OnInitializedAsync()
    {
        _brands = await BrandService.GetAllBrandsAsync();
    }

    private async Task DeleteBrand(int Id)
    {
        await BrandService.DeleteBrandAsync(Id);
        _brands = await BrandService.GetAllBrandsAsync();
    }
}
