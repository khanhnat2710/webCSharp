@page "/Brands/Create"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.brands
@inject IBrandService BrandService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Thêm thương hiệu</h3>
            <p class="page-subtitle">Tạo mới thương hiệu cho sản phẩm điện thoại.</p>
        </div>
    </div>

    <div class="form-card">
        <EditForm Model="brand" FormName="createBrand" OnValidSubmit="SaveBrand" class="stack-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Tên</label>
                <InputText @bind-Value="brand.Name" class="form-control" />
                <ValidationMessage For="() => brand.Name"/>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Lưu</button>
                <a class="btn btn-outline-primary" href="/Brands">Quay lại</a>
            </div>
        </EditForm>
    </div>
</section>
@code {
    public Brand brand = new Brand();
    [Inject] NavigationManager _navigationManager { get; set; }

    private async Task SaveBrand()
    {
        await BrandService.CreateBrandAsync(brand);
        _navigationManager.NavigateTo("/Brands", true);
    }
}
