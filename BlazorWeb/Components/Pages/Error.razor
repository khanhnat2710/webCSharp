@page "/Error"
@using System.Diagnostics

<PageTitle>Lỗi</PageTitle>

<h1 class="text-danger">Lỗi.</h1>
<h2 class="text-danger">Đã xảy ra lỗi khi xử lý yêu cầu của bạn.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@RequestId</code>
    </p>
}

<h3>Chế độ phát triển</h3>
<p>
    Khi chuyển sang môi trường <strong>Development</strong>, hệ thống sẽ hiển thị chi tiết hơn về lỗi đã xảy ra.
</p>
<p>
    <strong>Không nên bật môi trường Development trên hệ thống đang chạy thật.</strong>
    Điều này có thể làm lộ thông tin nhạy cảm từ lỗi hệ thống cho người dùng cuối.
    Để kiểm tra lỗi ở máy cục bộ, hãy đặt biến môi trường <strong>ASPNETCORE_ENVIRONMENT</strong> thành <strong>Development</strong>
    rồi khởi động lại ứng dụng.
</p>

@code{
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;

}
