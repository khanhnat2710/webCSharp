@page "/PaymentMethods/Create"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.PaymentMethods
@inject IPaymentService PaymentService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Thêm phương thức thanh toán</h3>
            <p class="page-subtitle">Tạo mới hình thức thanh toán cho đơn hàng.</p>
        </div>
    </div>

    <div class="form-card">
        <EditForm Model="paymentMethod" FormName="@CreateFormName" OnValidSubmit="SavePaymentMethod" class="stack-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Tên</label>
                <InputText @bind-Value="paymentMethod.Name" class="form-control" />
                <ValidationMessage For="() => paymentMethod.Name" />
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Lưu</button>
                <a class="btn btn-outline-primary" href="/PaymentMethods">Quay lại</a>
            </div>
        </EditForm>
    </div>
</section>

@code {
    private const string CreateFormName = "createPaymentMethod";

    [SupplyParameterFromForm(FormName = CreateFormName)]
    public PaymentMethod paymentMethod { get; set; } = new();

    [Inject] private NavigationManager NavigationManager { get; set; }

    private async Task SavePaymentMethod()
    {
        await PaymentService.CreatePaymentMethodAsync(paymentMethod);
        NavigationManager.NavigateTo("/PaymentMethods", true);
    }
}
