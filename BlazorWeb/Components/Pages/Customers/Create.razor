@page "/Customers/Create"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.Customers
@inject ICustomerService CustomerService

<section class="page-shell">
    <div class="page-header">
        <div>
            <h3 class="page-title">Thêm khách hàng</h3>
            <p class="page-subtitle">Tạo hồ sơ khách hàng mới cho cửa hàng.</p>
        </div>
    </div>

    <div class="form-card">
        <EditForm Model="customer" FormName="@CreateFormName" OnValidSubmit="SaveCustomer" class="stack-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Tên</label>
                <InputText @bind-Value="customer.Name" class="form-control" />
                <ValidationMessage For="() => customer.Name"/>
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="customer.Email" class="form-control" />
                <ValidationMessage For="() => customer.Email"/>
            </div>

            <div class="form-group">
                <label>Số điện thoại</label>
                <InputText @bind-Value="customer.Phone" class="form-control" />
                <ValidationMessage For="() => customer.Phone"/>
            </div>

            <div class="form-group">
                <label>Địa chỉ</label>
                <InputText @bind-Value="customer.Address" class="form-control" />
                <ValidationMessage For="() => customer.Address"/>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Lưu</button>
                <a class="btn btn-outline-primary" href="/Customers">Quay lại</a>
            </div>
        </EditForm>
    </div>
</section>

@code {
    private const string CreateFormName = "createCustomer";

    [SupplyParameterFromForm(FormName = CreateFormName)]
    public Customer customer { get; set; } = new();

    [Inject] NavigationManager _navigationManager { get; set; }

    private async Task SaveCustomer()
    {
        await CustomerService.CreateCustomerAsync(customer);
        _navigationManager.NavigateTo("/Customers", true);
    }
}
