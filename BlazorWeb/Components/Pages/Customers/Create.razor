@page "/Customers/Create"
@rendermode InteractiveServer
@using BlazorWeb.Models
@using BlazorWeb.Services.Customers
@inject ICustomerService CustomerService

<h3>Create</h3>
<EditForm Model="customer" FormName="createCustomer" OnValidSubmit="SaveCustomer">
    <DataAnnotationsValidator />
    <div class="form-group">
        <label>Name: </label>
        <InputText @bind-Value="customer.Name"/>
        <ValidationMessage For="() => customer.Name"/>
    </div>

    <div class="form-group">
        <label>Email: </label>
        <InputText @bind-Value="customer.Email"/>
        <ValidationMessage For="() => customer.Email"/>
    </div>

    <div class="form-group">
        <label>Phone: </label>
        <InputText @bind-Value="customer.Phone"/>
        <ValidationMessage For="() => customer.Phone"/>
    </div>

    <div class="form-group">
        <label>Address: </label>
        <InputText @bind-Value="customer.Address"/>
        <ValidationMessage For="() => customer.Address"/>
    </div>

    <div class="form-group">
        <button class="btn btn-primary" type="submit">
            Save
        </button>
    </div>
</EditForm>

@code {
    public Customer customer = new Customer();
    [Inject] NavigationManager _navigationManager { get; set; }

    private async Task SaveCustomer()
    {
        await CustomerService.CreateCustomerAsync(customer);
        _navigationManager.NavigateTo("/Customers", true);
    }
}
